{#if obj.example}
### Example Usage
```python
import gradio as gr

def generate(prompt, c=gr.Cache(per_session=True)):
    hit = c.get(prompt)
    if hit is not None:
        return hit["result"]
    result = llm(prompt)
    c.set(prompt, result=result)
    return result
```
