{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gradio-site",
	"main": "worker/index.ts",
	"compatibility_date": "2026-04-22",
	"preview_urls": true,
	"assets": {
		"directory": "./build",
		"binding": "ASSETS",
		"not_found_handling": "404-page",
		"run_worker_first": [
			"/docs/gradio/*",
			"/guides/*",
			"/main/docs/gradio/*",
			"/main/guides/*"
		]
	}
}
